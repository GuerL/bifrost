{
  "name": "Bifrost",
  "private": true,
  "version": "1.2.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "version:set": "node scripts/set-version.js",
    "version:patch": "node scripts/set-version.js --bump patch",
    "version:minor": "node scripts/set-version.js --bump minor",
    "version:major": "node scripts/set-version.js --bump major",
    "release:macos": "node scripts/build-macos-release.js",
    "release:windows": "node scripts/build-windows-release.js",
    "tauri": "tauri",
    "tauri:dev:windows": "tauri dev --config src-tauri/tauri.windows.conf.json",
    "tauri:build:windows": "tauri build --config src-tauri/tauri.windows.conf.json"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-select": "^2.2.6",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
